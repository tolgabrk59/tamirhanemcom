{
  "permissions": {
    "allow": [
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(git:*)",
      "Bash(mysql:*)",
      "Bash(python3:*)",
      "Bash(pip3:*)",
      "Bash(pm2:*)",
      "Bash(curl:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(find:*)",
      "Bash(tree:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(grep:*)",
      "Bash(echo:*)",
      "Bash(mkdir:*)",
      "Bash(mv:*)",
      "Bash(cp:*)",
      "Bash(rm:*)",
      "Bash(chmod:*)",
      "Bash(kill:*)",
      "Bash(pkill:*)",
      "Bash(pgrep:*)",
      "Bash(netstat:*)",
      "Bash(ss:*)",
      "Bash(dig:*)",
      "Bash(systemctl status:*)",
      "Bash(sudo systemctl:*)",
      "Bash(cloudflared:*)",
      "Bash(timeout:*)",
      "Bash(xargs:*)",
      "WebSearch",
      "WebFetch(domain:tamirhanem.com)",
      "WebFetch(domain:app.tamirhanem.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:vercel.com)",
      "WebFetch(domain:www.arabam.com)",
      "WebFetch(domain:www.sahibinden.com)",
      "Skill(*)",
      "Bash(npx vercel --version)",
      "Bash(claude --dangerously-skip-permissions /doctor:*)",
      "Bash(claude /doctor)",
      "Bash(npm run build:*)",
      "Bash(vercel:*)",
      "Bash(npm run lint:*)",
      "Bash(vercel --prod)",
      "Bash(vercel login:*)",
      "Bash(npm install:*)",
      "Bash(sh)",
      "Bash(curl -fsSL https://get.opencode.dev)",
      "Bash(go install:*)",
      "Bash(opencode --version:*)",
      "Bash(opencode /connect)",
      "Bash(npx tsc:*)",
      "Bash(npm ls:*)",
      "Bash(npm outdated:*)",
      "Bash(npm audit:*)",
      "Bash(nc:*)",
      "Bash(for:*)",
      "Bash(do)",
      "Bash(done)",
      "Bash(source:*)",
      "WebFetch(domain:docs.anthropic.com)",
      "Bash(do ss -tlnp)",
      "Bash(break)",
      "Bash(redis-cli:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/session-init.sh",
            "timeout": 10000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/scripts/session_hooks.py pre_tool",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/scripts/session_hooks.py post_tool",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
