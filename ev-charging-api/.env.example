# Database
DATABASE_URL="postgresql://user:password@localhost:5432/ev_charging?schema=public"

# OpenChargeMap API
OCM_API_KEY="your-ocm-api-key"
OCM_API_URL="https://api.openchargemap.io/v3"

# Google Places API (enrichment only)
GOOGLE_PLACES_API_KEY="your-google-places-api-key"

# Server
PORT=3001
NODE_ENV=development

# Pipeline
BATCH_SIZE=100
ENRICHMENT_DELAY_MS=200
