<!DOCTYPE html>
<html lang="tr">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Giriş Yap - TamirHanem">
  <title>Giriş Yap | TamirHanem</title>

  <!-- Favicon -->
  <link rel="icon" type="image/x-icon" href="/favicon/favicon.ico">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon/favicon-16x16.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png">
  <link rel="manifest" href="/favicon/site.webmanifest">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css" rel="stylesheet">

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
      min-height: 100vh;
      min-height: 100dvh;
      background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f0f23 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
      position: relative;
      overflow: hidden;
      -webkit-font-smoothing: antialiased;
    }

    html {
      min-height: 100%;
      height: 100%;
      background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f0f23 100%);
    }

    /* Animated Background */
    body::before {
      content: '';
      position: absolute;
      top: -50%;
      left: -50%;
      width: 200%;
      height: 200%;
      background: radial-gradient(circle, rgba(251, 199, 7, 0.03) 0%, transparent 50%);
      animation: pulse 15s ease-in-out infinite;
    }

    @keyframes pulse {
      0%, 100% { transform: translate(0, 0) scale(1); }
      50% { transform: translate(10%, 10%) scale(1.1); }
    }

    /* Floating Shapes with Icons */
    .floating-shape {
      position: absolute;
      border-radius: 50%;
      background: linear-gradient(135deg, rgba(251, 199, 7, 0.08), rgba(251, 199, 7, 0.02));
      display: flex;
      align-items: center;
      justify-content: center;
      animation: float 20s ease-in-out infinite;
    }

    .floating-shape i {
      font-size: 4rem;
      color: rgba(251, 199, 7, 0.15);
    }

    .shape-1 {
      width: 300px;
      height: 300px;
      top: 5%;
      left: 3%;
      animation-delay: 0s;
    }

    .shape-1 i { font-size: 5rem; }

    .shape-2 {
      width: 220px;
      height: 220px;
      bottom: 10%;
      right: 5%;
      animation-delay: -5s;
    }

    .shape-2 i { font-size: 4rem; }

    .shape-3 {
      width: 180px;
      height: 180px;
      top: 55%;
      left: 8%;
      animation-delay: -10s;
    }

    .shape-3 i { font-size: 3.5rem; }

    .shape-4 {
      width: 160px;
      height: 160px;
      top: 15%;
      right: 8%;
      animation-delay: -3s;
    }

    .shape-4 i { font-size: 3rem; }

    .shape-5 {
      width: 120px;
      height: 120px;
      bottom: 25%;
      left: 20%;
      animation-delay: -8s;
    }

    .shape-5 i { font-size: 2.5rem; }

    @keyframes float {
      0%, 100% { transform: translateY(0) rotate(0deg); }
      33% { transform: translateY(-20px) rotate(5deg); }
      66% { transform: translateY(20px) rotate(-5deg); }
    }

    /* Login Container */
    .login-container {
      width: 100%;
      max-width: 440px;
      position: relative;
      z-index: 10;
      transform: translateY(-20px);
    }

    /* Logo */
    .logo-section {
      text-align: center;
      margin-bottom: 20px;
      position: relative;
      z-index: 10;
    }

    .logo-section img {
      height: clamp(160px, 22vh, 200px);
      width: auto;
      filter: drop-shadow(0 4px 20px rgba(251, 199, 7, 0.3));
      transform: translate(20px, 25px);
    }

    /* Login Card */
    .login-card {
      background: rgba(90, 90, 90, 0.15);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border-radius: 24px;
      border: 1px solid rgba(90, 90, 90, 0.3);
      padding: 40px;
      box-shadow: 0 25px 50px rgba(0, 0, 0, 0.3);
      position: relative;
      margin-top: -15px;
    }

    /* Header */
    .login-header {
      text-align: center;
      margin-bottom: 32px;
    }

    .login-header h1 {
      font-size: 1.8rem;
      font-weight: 800;
      color: #ffffff;
      margin-bottom: 8px;
    }

    .login-header p {
      color: rgba(255, 255, 255, 0.5);
      font-size: 0.95rem;
    }

    /* Form */
    .form-group {
      margin-bottom: 20px;
    }

    .form-label {
      display: block;
      font-weight: 600;
      color: rgba(255, 255, 255, 0.7);
      font-size: 0.85rem;
      margin-bottom: 8px;
    }

    .input-wrapper {
      position: relative;
    }

    .input-wrapper i {
      position: absolute;
      left: 16px;
      top: 50%;
      transform: translateY(-50%);
      color: rgba(255, 255, 255, 0.3);
      font-size: 1.1rem;
      transition: color 0.3s;
    }

    .form-input {
      width: 100%;
      padding: 16px 16px 16px 48px;
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 12px;
      font-size: 1rem;
      color: #ffffff;
      font-family: inherit;
      transition: all 0.3s;
    }

    .form-input::placeholder {
      color: rgba(255, 255, 255, 0.3);
    }

    .form-input:focus {
      outline: none;
      border-color: #fbc707;
      background: rgba(251, 199, 7, 0.05);
      box-shadow: 0 0 0 4px rgba(251, 199, 7, 0.1);
    }

    .form-input:focus + i {
      color: #fbc707;
    }

    .input-error {
      border-color: #ef4444 !important;
      background: rgba(239, 68, 68, 0.05) !important;
    }

    .error-message {
      color: #ef4444;
      font-size: 0.8rem;
      margin-top: 6px;
      display: block;
    }

    /* Password Toggle */
    .password-toggle {
      position: absolute;
      right: 16px;
      top: 50%;
      transform: translateY(-50%);
      background: none;
      border: none;
      color: rgba(255, 255, 255, 0.3);
      cursor: pointer;
      font-size: 1.1rem;
      transition: color 0.3s;
    }

    .password-toggle:hover {
      color: #fbc707;
    }

    /* Options Row */
    .options-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 24px;
    }

    .checkbox-wrapper {
      display: flex;
      align-items: center;
      gap: 8px;
      cursor: pointer;
    }

    .checkbox-wrapper input {
      width: 18px;
      height: 18px;
      accent-color: #fbc707;
      cursor: pointer;
    }

    .checkbox-wrapper label {
      color: rgba(255, 255, 255, 0.6);
      font-size: 0.9rem;
      cursor: pointer;
    }

    .forgot-link {
      color: #fbc707;
      font-weight: 600;
      font-size: 0.9rem;
      text-decoration: none;
      transition: all 0.3s;
    }

    .forgot-link:hover {
      text-decoration: underline;
      filter: brightness(1.1);
    }

    /* Submit Button */
    .btn-submit {
      width: 100%;
      padding: 16px;
      background: linear-gradient(135deg, #fbc707 0%, #e5b306 100%);
      border: none;
      border-radius: 12px;
      font-size: 1rem;
      font-weight: 700;
      color: #1a1a2e;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      transition: all 0.3s;
      box-shadow: 0 8px 24px rgba(251, 199, 7, 0.25);
    }

    .btn-submit:hover {
      transform: translateY(-2px);
      box-shadow: 0 12px 32px rgba(251, 199, 7, 0.35);
    }

    .btn-submit:active {
      transform: translateY(0);
    }

    .btn-submit:disabled {
      opacity: 0.7;
      cursor: not-allowed;
      transform: none;
    }

    /* Footer */
    .login-footer {
      text-align: center;
      margin-top: 24px;
      color: rgba(255, 255, 255, 0.5);
      font-size: 0.95rem;
    }

    .login-footer a {
      color: #fbc707;
      font-weight: 700;
      text-decoration: none;
      margin-left: 4px;
    }

    .login-footer a:hover {
      text-decoration: underline;
    }

    /* Divider */
    .divider {
      display: flex;
      align-items: center;
      margin: 24px 0;
      color: rgba(255, 255, 255, 0.3);
      font-size: 0.85rem;
    }

    .divider::before,
    .divider::after {
      content: '';
      flex: 1;
      height: 1px;
      background: rgba(255, 255, 255, 0.1);
    }

    .divider span {
      padding: 0 16px;
    }

    /* Features */
    .features {
      display: flex;
      justify-content: center;
      gap: 24px;
      margin-top: 32px;
      flex-wrap: wrap;
    }

    .feature-item {
      display: flex;
      align-items: center;
      gap: 8px;
      color: rgba(255, 255, 255, 0.4);
      font-size: 0.8rem;
    }

    .feature-item i {
      color: #fbc707;
      font-size: 1rem;
    }

    /* Loading */
    #global-loading {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(26, 26, 46, 0.95);
      z-index: 9999;
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      pointer-events: none;
      transition: 0.3s;
    }

    #global-loading.active {
      opacity: 1;
      pointer-events: auto;
    }

    .spinner {
      width: 50px;
      height: 50px;
      border: 4px solid rgba(255, 255, 255, 0.1);
      border-top-color: #fbc707;
      border-radius: 50%;
      animation: spin 1s linear infinite;
    }

    @keyframes spin {
      to { transform: rotate(360deg); }
    }

    /* Service Selection Modal */
    .service-modal {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(90, 90, 90, 0.95);
      backdrop-filter: blur(15px);
      z-index: 10002;
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      pointer-events: none;
      transition: all 0.4s ease;
      padding: 20px;
    }

    .service-modal.active {
      opacity: 1;
      pointer-events: auto;
    }

    .service-modal-content {
      background: rgba(90, 90, 90, 0.3);
      backdrop-filter: blur(20px);
      border-radius: 28px;
      padding: 45px;
      max-width: 520px;
      width: 100%;
      max-height: 85vh;
      overflow-y: auto;
      border: 2px solid rgba(251, 199, 7, 0.3);
      box-shadow: 0 30px 60px rgba(0, 0, 0, 0.4), 0 0 40px rgba(251, 199, 7, 0.1);
      animation: serviceModalPop 0.5s cubic-bezier(0.68, -0.55, 0.265, 1.55);
    }

    @keyframes serviceModalPop {
      0% { transform: scale(0.8); opacity: 0; }
      100% { transform: scale(1); opacity: 1; }
    }

    .service-modal-header {
      text-align: center;
      margin-bottom: 35px;
    }

    .service-modal-header i {
      font-size: 3rem;
      color: #fbc707;
      margin-bottom: 15px;
      display: block;
      animation: bounce 2s ease-in-out infinite;
    }

    @keyframes bounce {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-10px); }
    }

    .service-modal-title {
      font-size: 1.8rem;
      font-weight: 800;
      color: #ffffff;
      margin-bottom: 10px;
    }

    .service-modal-subtitle {
      color: rgba(255, 255, 255, 0.6);
      font-size: 1rem;
    }

    .service-list {
      display: flex;
      flex-direction: column;
      gap: 14px;
    }

    .service-item {
      background: rgba(255, 255, 255, 0.08);
      border: 1px solid rgba(255, 255, 255, 0.15);
      border-radius: 18px;
      padding: 18px 20px;
      cursor: pointer;
      transition: all 0.3s ease;
      display: flex;
      align-items: center;
      gap: 18px;
    }

    .service-item:hover {
      border-color: #fbc707;
      background: rgba(251, 199, 7, 0.15);
      transform: translateX(8px);
      box-shadow: 0 8px 25px rgba(251, 199, 7, 0.2);
    }

    .service-item-img {
      width: 60px;
      height: 60px;
      border-radius: 14px;
      object-fit: cover;
      flex-shrink: 0;
      border: 2px solid rgba(251, 199, 7, 0.3);
    }

    .service-item-info {
      flex: 1;
    }

    .service-item-name {
      font-weight: 700;
      color: #ffffff;
      font-size: 1.1rem;
      margin-bottom: 5px;
    }

    .service-item-location {
      color: rgba(255, 255, 255, 0.6);
      font-size: 0.9rem;
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .service-item-location i {
      color: #fbc707;
    }

    .service-item i.ri-arrow-right-s-line {
      color: #fbc707;
      font-size: 1.8rem;
      transition: transform 0.3s;
    }

    .service-item:hover i.ri-arrow-right-s-line {
      transform: translateX(5px);
    }

    .skip-btn {
      margin-top: 25px;
      text-align: center;
    }

    .skip-btn a {
      color: rgba(255, 255, 255, 0.6);
      text-decoration: none;
      font-weight: 600;
      font-size: 0.95rem;
      transition: all 0.3s;
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }

    .skip-btn a:hover {
      color: #fbc707;
    }

    /* Responsive */
    @media (max-width: 480px) {
      .login-card {
        padding: 30px 24px;
      }

      .login-header h1 {
        font-size: 1.5rem;
      }

      .features {
        gap: 16px;
      }

      .feature-item {
        font-size: 0.75rem;
      }
    }

    /* ==================== SUCCESS / ERROR MODAL ==================== */
    .result-modal {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(90, 90, 90, 0.92);
      backdrop-filter: blur(10px);
      z-index: 10001;
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      pointer-events: none;
      transition: all 0.4s ease;
    }

    .result-modal.active {
      opacity: 1;
      pointer-events: auto;
    }

    .result-modal-content {
      text-align: center;
      padding: 40px;
      animation: modalBounce 0.6s cubic-bezier(0.68, -0.55, 0.265, 1.55);
    }

    @keyframes modalBounce {
      0% { transform: scale(0.3); opacity: 0; }
      50% { transform: scale(1.05); }
      70% { transform: scale(0.95); }
      100% { transform: scale(1); opacity: 1; }
    }

    /* Success - Car Theme */
    .success-car {
      width: 140px;
      height: 140px;
      margin: 0 auto 24px;
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .success-car .car-circle {
      width: 140px;
      height: 140px;
      border-radius: 50%;
      background: linear-gradient(135deg, rgba(251, 199, 7, 0.15), rgba(251, 199, 7, 0.05));
      border: 3px solid #fbc707;
      display: flex;
      align-items: center;
      justify-content: center;
      animation: pulse-circle 2s ease-in-out infinite;
      box-shadow: 0 0 40px rgba(251, 199, 7, 0.3);
    }

    @keyframes pulse-circle {
      0%, 100% { transform: scale(1); box-shadow: 0 0 40px rgba(251, 199, 7, 0.3); }
      50% { transform: scale(1.05); box-shadow: 0 0 60px rgba(251, 199, 7, 0.5); }
    }

    .success-car .car-icon {
      font-size: 4rem;
      color: #fbc707;
      animation: car-drive 1s ease-out;
    }

    @keyframes car-drive {
      0% { transform: translateX(-50px); opacity: 0; }
      50% { transform: translateX(10px); }
      100% { transform: translateX(0); opacity: 1; }
    }

    .success-car .check-badge {
      position: absolute;
      bottom: 5px;
      right: 5px;
      width: 40px;
      height: 40px;
      background: linear-gradient(135deg, #4ade80, #22c55e);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-size: 1.2rem;
      animation: badge-pop 0.5s ease-out 0.5s both;
      box-shadow: 0 4px 15px rgba(74, 222, 128, 0.4);
    }

    @keyframes badge-pop {
      0% { transform: scale(0); }
      50% { transform: scale(1.2); }
      100% { transform: scale(1); }
    }

    /* Error - Car Theme */
    .error-car {
      width: 140px;
      height: 140px;
      margin: 0 auto 24px;
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .error-car .car-circle {
      width: 140px;
      height: 140px;
      border-radius: 50%;
      background: linear-gradient(135deg, rgba(239, 68, 68, 0.15), rgba(239, 68, 68, 0.05));
      border: 3px solid #ef4444;
      display: flex;
      align-items: center;
      justify-content: center;
      animation: shake-circle 0.5s ease-in-out;
      box-shadow: 0 0 40px rgba(239, 68, 68, 0.3);
    }

    @keyframes shake-circle {
      0%, 100% { transform: translateX(0); }
      20%, 60% { transform: translateX(-8px); }
      40%, 80% { transform: translateX(8px); }
    }

    .error-car .car-icon {
      font-size: 4rem;
      color: #ef4444;
      opacity: 0.6;
    }

    .error-car .warning-badge {
      position: absolute;
      bottom: 5px;
      right: 5px;
      width: 40px;
      height: 40px;
      background: linear-gradient(135deg, #ef4444, #dc2626);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-size: 1.2rem;
      animation: badge-shake 0.5s ease-out;
      box-shadow: 0 4px 15px rgba(239, 68, 68, 0.4);
    }

    @keyframes badge-shake {
      0%, 100% { transform: rotate(0); }
      25% { transform: rotate(-10deg); }
      75% { transform: rotate(10deg); }
    }

    .result-title {
      font-size: 1.8rem;
      font-weight: 800;
      margin-bottom: 12px;
    }

    .result-title.success { color: #fbc707; }
    .result-title.error { color: #ef4444; }

    .result-message {
      color: rgba(255, 255, 255, 0.7);
      font-size: 1rem;
      margin-bottom: 24px;
    }

    .result-redirect {
      color: rgba(255, 255, 255, 0.5);
      font-size: 0.9rem;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
    }

    .result-redirect i {
      animation: spin 1s linear infinite;
    }

    /* Falling Tamirhane Icons Animation */
    .falling-icon {
      position: absolute;
      font-size: 24px;
      color: #5a5a5a;
      animation: icon-fall 3.5s ease-out forwards;
      text-shadow: 0 2px 10px rgba(90, 90, 90, 0.5);
    }

    @keyframes icon-fall {
      0% {
        transform: translateY(0) rotate(0deg) scale(1);
        opacity: 1;
      }
      50% {
        opacity: 0.8;
      }
      100% {
        transform: translateY(500px) rotate(720deg) scale(0.5);
        opacity: 0;
      }
    }
  </style>
</head>

<body>
  <!-- Floating Shapes -->
  <div class="floating-shape shape-1"><i class="ri-settings-3-fill"></i></div>
  <div class="floating-shape shape-2"><i class="ri-roadster-fill"></i></div>
  <div class="floating-shape shape-3"><i class="ri-tools-fill"></i></div>
  <div class="floating-shape shape-4"><i class="ri-steering-2-fill"></i></div>
  <div class="floating-shape shape-5"><i class="ri-hammer-fill"></i></div>

  <div class="login-container">
    <!-- Logo -->
    <div class="logo-section">
      <a href="/">
        <img src="/images/logov2.png" alt="TamirHanem">
      </a>
    </div>

    <!-- Login Card -->
    <div class="login-card">
      <div class="login-header">
        <h1>Hoş Geldiniz!</h1>
        <p>Hesabınıza giriş yaparak devam edin</p>
      </div>

      <form id="login-form">
        <div class="form-group">
          <label class="form-label">Email veya Telefon</label>
          <div class="input-wrapper">
            <input type="text" id="identifier" class="form-input" placeholder="ornek@email.com" required autocomplete="username">
            <i class="ri-user-line"></i>
          </div>
          <span class="error-message" id="identifier-error"></span>
        </div>

        <div class="form-group">
          <label class="form-label">Şifre</label>
          <div class="input-wrapper">
            <input type="password" id="password" class="form-input" placeholder="••••••••" required autocomplete="current-password">
            <i class="ri-lock-password-line"></i>
            <button type="button" class="password-toggle" id="password-toggle">
              <i class="ri-eye-line"></i>
            </button>
          </div>
          <span class="error-message" id="password-error"></span>
        </div>

        <div class="options-row">
          <div class="checkbox-wrapper">
            <input type="checkbox" id="remember" name="remember">
            <label for="remember">Beni Hatırla</label>
          </div>
          <a href="/forgot-password.html" class="forgot-link">Şifremi Unuttum?</a>
        </div>

        <button type="submit" class="btn-submit" id="login-btn">
          Giriş Yap <i class="ri-arrow-right-line"></i>
        </button>
      </form>

      <div class="login-footer">
        Hesabınız yok mu?<a href="/register.html">Hemen Kayıt Olun</a>
      </div>
    </div>

    <!-- Features -->
    <div class="features">
      <div class="feature-item">
        <i class="ri-shield-check-line"></i>
        <span>Güvenli Giriş</span>
      </div>
      <div class="feature-item">
        <i class="ri-lock-line"></i>
        <span>256-bit SSL</span>
      </div>
      <div class="feature-item">
        <i class="ri-customer-service-2-line"></i>
        <span>7/24 Destek</span>
      </div>
    </div>
  </div>

  <div id="global-loading">
    <div class="spinner"></div>
  </div>

  <!-- Success Modal -->
  <div class="result-modal" id="success-modal">
    <div class="result-modal-content">
      <div class="success-car">
        <div class="car-circle">
          <i class="ri-roadster-fill car-icon" id="success-icon"></i>
        </div>
        <div class="check-badge">
          <i class="ri-check-line"></i>
        </div>
      </div>
      <h2 class="result-title success" id="success-title">Hoş Geldiniz!</h2>
      <p class="result-message" id="success-message">Giriş başarılı, aracınız hazır!</p>
      <div class="result-redirect">
        <i class="ri-steering-2-line"></i>
        <span id="success-redirect-text">Panele yönlendiriliyorsunuz...</span>
      </div>
    </div>
  </div>

  <!-- Error Modal -->
  <div class="result-modal" id="error-modal">
    <div class="result-modal-content">
      <div class="error-car">
        <div class="car-circle">
          <i class="ri-roadster-fill car-icon"></i>
        </div>
        <div class="warning-badge">
          <i class="ri-close-line"></i>
        </div>
      </div>
      <h2 class="result-title error">Giriş Başarısız!</h2>
      <p class="result-message" id="error-modal-message">Kullanıcı adı veya şifre hatalı.</p>
      <button class="btn-submit" onclick="closeErrorModal()" style="max-width: 200px; margin: 0 auto;">
        <i class="ri-refresh-line"></i> Tekrar Dene
      </button>
    </div>
  </div>

  <!-- Service Selection Modal -->
  <div class="service-modal" id="service-modal">
    <div class="service-modal-content">
      <div class="service-modal-header">
        <i class="ri-building-4-fill"></i>
        <h2 class="service-modal-title">Servis Seçimi</h2>
        <p class="service-modal-subtitle">Hangi servis hesabıyla devam etmek istiyorsunuz?</p>
      </div>
      <div class="service-list" id="service-list"></div>
      <div class="skip-btn">
        <a href="#" id="skip-service-selection">
          <i class="ri-user-line"></i> Normal kullanıcı olarak devam et
        </a>
      </div>
    </div>
  </div>

  <script src="/js/config.js"></script>
  <script src="/js/utils.js"></script>
  <script src="/js/api.js"></script>
  <script src="/js/auth.js"></script>
  <script src="/js/store.js"></script>

  <script>
    // Redirect if already authenticated
    if (auth.isAuthenticated()) window.location.href = '/dashboard.html';

    // Success/Error Modal Functions
    function showSuccessModal() {
      const modal = document.getElementById('success-modal');
      modal.classList.add('active');
      createFallingIcons();
    }

    function showErrorModal(message) {
      const modal = document.getElementById('error-modal');
      const messageEl = document.getElementById('error-modal-message');
      messageEl.textContent = message || 'Kullanıcı adı veya şifre hatalı.';
      modal.classList.add('active');
    }

    function closeErrorModal() {
      const modal = document.getElementById('error-modal');
      modal.classList.remove('active');
    }

    function createFallingIcons() {
      const icons = [
        'ri-tools-fill',        // Aletler
        'ri-settings-3-fill',   // Çark dişli
        'ri-hammer-fill',       // Çekiç
        'ri-car-fill',          // Araba
        'ri-roadster-fill',     // Spor araba
        'ri-steering-2-fill',   // Direksiyon
        'ri-car-washing-fill',  // Araba yıkama
        'ri-gas-station-fill',  // Benzin
        'ri-key-2-fill',        // Anahtar
        'ri-timer-flash-fill'   // Hızlı servis
      ];
      const colors = ['#fbc707', '#eeb902', '#fcd34d', '#5a5a5a', '#6a6a6a'];
      const modal = document.getElementById('success-modal');

      for (let i = 0; i < 30; i++) {
        const icon = document.createElement('i');
        icon.className = `falling-icon ${icons[Math.floor(Math.random() * icons.length)]}`;
        icon.style.left = Math.random() * 100 + '%';
        icon.style.top = '-30px';
        icon.style.color = colors[Math.floor(Math.random() * colors.length)];
        icon.style.animationDelay = Math.random() * 2 + 's';
        icon.style.animationDuration = (Math.random() * 2 + 2.5) + 's';
        icon.style.fontSize = (Math.random() * 16 + 18) + 'px';
        modal.appendChild(icon);

        setTimeout(() => icon.remove(), 5000);
      }
    }

    // Password Toggle
    const passwordToggle = document.getElementById('password-toggle');
    const passwordInput = document.getElementById('password');
    const passwordIcon = passwordToggle.querySelector('i');

    passwordToggle.addEventListener('click', () => {
      const type = passwordInput.type === 'password' ? 'text' : 'password';
      passwordInput.type = type;
      passwordIcon.className = type === 'password' ? 'ri-eye-line' : 'ri-eye-off-line';
    });

    // Form Submit
    const loginForm = document.getElementById('login-form');
    const loginBtn = document.getElementById('login-btn');
    const identifierInput = document.getElementById('identifier');
    const identifierError = document.getElementById('identifier-error');
    const passwordError = document.getElementById('password-error');

    loginForm.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Reset errors
      identifierError.textContent = '';
      passwordError.textContent = '';
      identifierInput.classList.remove('input-error');
      passwordInput.classList.remove('input-error');

      const identifier = identifierInput.value.trim();
      const password = passwordInput.value;

      if (!identifier) {
        identifierError.textContent = 'Email veya telefon gerekli';
        identifierInput.classList.add('input-error');
        return;
      }
      if (!password || password.length < 6) {
        passwordError.textContent = 'Şifre en az 6 karakter olmalı';
        passwordInput.classList.add('input-error');
        return;
      }

      loginBtn.disabled = true;
      loginBtn.innerHTML = '<i class="ri-loader-4-line" style="animation:spin 1s infinite"></i> Giriş yapılıyor...';
      Utils.showLoading();

      try {
        const result = await auth.login(identifier, password);

        if (result.success) {
          Utils.hideLoading();
          const userId = result.user?.id || result.user?.userId;

          if (userId) {
            // Önce servisleri kontrol et
            await checkUserServices(userId);
          } else {
            // Normal kullanıcı - success modal göster
            showSuccessModal();
            localStorage.setItem('isServiceOwner', 'false');
            localStorage.removeItem('selectedServiceId');
            setTimeout(() => { window.location.href = '/dashboard.html'; }, 2500);
          }
        } else {
          Utils.hideLoading();
          loginBtn.disabled = false;
          loginBtn.innerHTML = 'Giriş Yap <i class="ri-arrow-right-line"></i>';
          showErrorModal(result.error || 'Kullanıcı adı veya şifre hatalı.');
        }
      } catch (error) {
        Utils.hideLoading();
        loginBtn.disabled = false;
        loginBtn.innerHTML = 'Giriş Yap <i class="ri-arrow-right-line"></i>';
        showErrorModal('Bir hata oluştu. Lütfen tekrar deneyin.');
      }
    });

    // Check User Services
    async function checkUserServices(userId) {
      try {
        const token = auth.getToken();
        const apiUrl = `${CONFIG.API_BASE_URL}/services?populate=ProfilePicture&filters[user][id][$eq]=${userId}`;
        const response = await fetch(apiUrl, { headers: { Authorization: `Bearer ${token}` } });
        const data = await response.json();

        if (response.ok && Array.isArray(data.data) && data.data.length > 0) {
          // Servis sahibi - direkt servis seçim modalını göster (animasyon yok)
          showServiceSelectionModal(data.data);
        } else {
          // Normal kullanıcı - success modal göster
          showSuccessModal();
          localStorage.setItem('isServiceOwner', 'false');
          localStorage.removeItem('selectedServiceId');
          setTimeout(() => { window.location.href = '/dashboard.html'; }, 2500);
        }
      } catch (error) {
        // Hata durumunda normal kullanıcı olarak devam
        showSuccessModal();
        localStorage.setItem('isServiceOwner', 'false');
        localStorage.removeItem('selectedServiceId');
        setTimeout(() => { window.location.href = '/dashboard.html'; }, 2500);
      }
    }

    // Show Service Selection Modal
    function showServiceSelectionModal(services) {
      const modal = document.getElementById('service-modal');
      const serviceList = document.getElementById('service-list');

      const mappedServices = services.map(item => ({
        id: item.id,
        name: item.attributes.name,
        location: item.attributes.location || 'Konum yok',
        ProfilePicture: item.attributes.ProfilePicture?.data
          ? Utils.getImageUrl(item.attributes.ProfilePicture.data.attributes)
          : 'https://via.placeholder.com/50'
      }));

      serviceList.innerHTML = mappedServices.map(service => `
        <div class="service-item" data-service-id="${service.id}" data-service-name="${service.name.replace(/"/g, '&quot;')}">
          <img src="${service.ProfilePicture}" class="service-item-img" alt="${service.name}">
          <div class="service-item-info">
            <div class="service-item-name">${service.name}</div>
            <div class="service-item-location"><i class="ri-map-pin-line"></i> ${service.location}</div>
          </div>
          <i class="ri-arrow-right-s-line"></i>
        </div>
      `).join('');

      document.querySelectorAll('.service-item').forEach(item => {
        item.addEventListener('click', function() {
          selectService(this.dataset.serviceId, this.dataset.serviceName);
        });
      });

      modal.classList.add('active');
    }

    // Select Service
    function selectService(serviceId, serviceName) {
      localStorage.setItem('isServiceOwner', 'true');
      localStorage.setItem('selectedServiceId', serviceId.toString());
      localStorage.setItem('selectedServiceName', serviceName || 'Servis');

      // Servis modalını kapat
      document.getElementById('service-modal').classList.remove('active');

      // Servis için özel success modal göster
      showServiceSuccessModal(serviceName);

      setTimeout(() => { window.location.href = '/dashboard.html'; }, 2500);
    }

    // Servis seçimi sonrası success modal
    function showServiceSuccessModal(serviceName) {
      document.getElementById('success-icon').className = 'ri-building-4-fill car-icon';
      document.getElementById('success-title').textContent = 'Servis Paneline Hoş Geldiniz!';
      document.getElementById('success-message').textContent = `${serviceName} hesabıyla giriş yapıldı`;
      document.getElementById('success-redirect-text').textContent = 'Servis paneline yönlendiriliyorsunuz...';

      const modal = document.getElementById('success-modal');
      modal.classList.add('active');
      createFallingIcons();
    }

    // Skip Service Selection
    document.getElementById('skip-service-selection').addEventListener('click', (e) => {
      e.preventDefault();
      localStorage.setItem('isServiceOwner', 'false');
      localStorage.removeItem('selectedServiceId');
      localStorage.removeItem('selectedServiceName');

      // Servis modalını kapat
      document.getElementById('service-modal').classList.remove('active');

      // Normal kullanıcı success modal göster
      showSuccessModal();
      setTimeout(() => { window.location.href = '/dashboard.html'; }, 2500);
    });

    // Remember Me Logic
    const rememberCheckbox = document.getElementById('remember');
    const savedUser = localStorage.getItem('th_remember_user');
    if (savedUser) {
      identifierInput.value = savedUser;
      rememberCheckbox.checked = true;
    }

    loginForm.addEventListener('submit', () => {
      if (rememberCheckbox.checked) localStorage.setItem('th_remember_user', identifierInput.value);
      else localStorage.removeItem('th_remember_user');
    });
  </script>
</body>

</html>
