/**
 * TamirHanem Web - Component Styles
 * Button, Card, Input, Modal, Toast, Loading, vb.
 */

/* ============================================
   BUTTON COMPONENT
   ============================================ */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  padding: 0.75rem 1.5rem;
  font-size: var(--font-size-base);
  font-weight: 600;
  line-height: 1;
  border: none;
  border-radius: var(--radius-lg);
  cursor: pointer;
  transition: all var(--transition-base);
  text-decoration: none;
  white-space: nowrap;
}

.btn:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

/* Button Variants */
.btn-primary {
  background: var(--gradient-primary);
  color: var(--color-text-primary);
  box-shadow: var(--shadow-md);
}

.btn-primary:hover:not(:disabled) {
  transform: translateY(-2px);
  box-shadow: var(--shadow-lg);
}

.btn-primary:active:not(:disabled) {
  transform: translateY(0);
}

.btn-outline {
  background: transparent;
  border: 2px solid var(--color-primary);
  color: var(--color-primary);
}

.btn-outline:hover:not(:disabled) {
  background: var(--color-primary);
  color: var(--color-text-primary);
}

.btn-ghost {
  background: transparent;
  color: var(--color-text-primary);
}

.btn-ghost:hover:not(:disabled) {
  background: rgba(0, 0, 0, 0.05);
}

.btn-white {
  background: white;
  color: var(--color-text-primary);
  box-shadow: var(--shadow-md);
}

.btn-white:hover:not(:disabled) {
  transform: translateY(-2px);
  box-shadow: var(--shadow-lg);
}

/* Button Sizes */
.btn-sm {
  padding: 0.5rem 1rem;
  font-size: var(--font-size-sm);
  border-radius: var(--radius-md);
}

.btn-lg {
  padding: 1rem 2rem;
  font-size: var(--font-size-lg);
  border-radius: var(--radius-xl);
}

.btn-full {
  width: 100%;
}

/* ============================================
   CARD COMPONENT
   ============================================ */
.card {
  background: white;
  border-radius: var(--radius-lg);
  padding: var(--spacing-lg);
  box-shadow: var(--shadow-md);
  transition: all var(--transition-base);
}

.card-hover:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-xl);
}

.card-gradient {
  background: linear-gradient(135deg, rgba(255, 197, 7, 0.1) 0%, rgba(255, 255, 255, 1) 100%);
}

.card-header {
  padding-bottom: var(--spacing-md);
  margin-bottom: var(--spacing-md);
  border-bottom: 1px solid rgba(0, 0, 0, 0.1);
}

.card-body {
  padding: var(--spacing-md) 0;
}

.card-footer {
  padding-top: var(--spacing-md);
  margin-top: var(--spacing-md);
  border-top: 1px solid rgba(0, 0, 0, 0.1);
}

/* Service Card */
.service-card {
  background: white;
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-md);
  transition: all var(--transition-base);
  cursor: pointer;
}

.service-card:hover {
  transform: translateY(-6px);
  box-shadow: var(--shadow-2xl);
}

.service-card-image {
  width: 100%;
  height: 200px;
  object-fit: cover;
}

.service-card-content {
  padding: var(--spacing-lg);
}

.service-card-title {
  font-size: var(--font-size-xl);
  font-weight: 700;
  margin-bottom: var(--spacing-sm);
  color: var(--color-text-primary);
}

.service-card-location {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  color: var(--color-text-tertiary);
  font-size: var(--font-size-sm);
  margin-bottom: var(--spacing-sm);
}

.service-card-rating {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  margin-bottom: var(--spacing-md);
}

.service-card-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.25rem;
  padding: 0.25rem 0.75rem;
  font-size: var(--font-size-xs);
  font-weight: 600;
  border-radius: var(--radius-full);
  background: var(--color-primary-soft);
  color: var(--color-text-primary);
}

/* ============================================
   INPUT COMPONENT
   ============================================ */
.input-group {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  margin-bottom: var(--spacing-lg);
}

.input-label {
  font-size: var(--font-size-sm);
  font-weight: 600;
  color: var(--color-text-primary);
}

.input,
.textarea,
.select {
  width: 100%;
  padding: 0.75rem 1rem;
  font-size: var(--font-size-base);
  font-family: var(--font-family);
  color: var(--color-text-primary);
  background: white;
  border: 2px solid #E5E7EB;
  border-radius: var(--radius-md);
  transition: all var(--transition-fast);
}

.input:focus,
.textarea:focus,
.select:focus {
  outline: none;
  border-color: var(--color-primary);
  box-shadow: 0 0 0 3px rgba(255, 197, 7, 0.1);
}

.input::placeholder,
.textarea::placeholder {
  color: var(--color-text-muted);
}

.input-error {
  border-color: var(--color-error);
}

.input-error:focus {
  box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.1);
}

.input-error-message {
  font-size: var(--font-size-sm);
  color: var(--color-error);
  margin-top: 0.25rem;
}

.textarea {
  min-height: 100px;
  resize: vertical;
}

/* Search Input */
.search-input-wrapper {
  position: relative;
  width: 100%;
}

.search-input {
  padding-left: 3rem;
}

.search-icon {
  position: absolute;
  left: 1rem;
  top: 50%;
  transform: translateY(-50%);
  color: var(--color-text-muted);
}

/* ============================================
   BADGE COMPONENT
   ============================================ */
.badge {
  display: inline-flex;
  align-items: center;
  gap: 0.25rem;
  padding: 0.25rem 0.75rem;
  font-size: var(--font-size-xs);
  font-weight: 600;
  border-radius: var(--radius-full);
  white-space: nowrap;
}

.badge-primary {
  background: var(--color-primary-soft);
  color: var(--color-text-primary);
}

.badge-success {
  background: rgba(16, 185, 129, 0.1);
  color: var(--color-success);
}

.badge-warning {
  background: rgba(245, 158, 11, 0.1);
  color: var(--color-warning);
}

.badge-error {
  background: rgba(239, 68, 68, 0.1);
  color: var(--color-error);
}

.badge-info {
  background: rgba(59, 130, 246, 0.1);
  color: var(--color-info);
}

/* ============================================
   RATING STARS
   ============================================ */
.rating {
  display: flex;
  align-items: center;
  gap: 0.25rem;
}

.star {
  font-size: var(--font-size-lg);
  line-height: 1;
}

.star-full {
  color: #FBBF24;
}

.star-half {
  color: #FBBF24;
  opacity: 0.5;
}

.star-empty {
  color: #D1D5DB;
}

/* ============================================
   MODAL COMPONENT
   ============================================ */
.modal-backdrop {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: var(--z-modal-backdrop);
  opacity: 0;
  visibility: hidden;
  transition: all var(--transition-base);
  padding: var(--spacing-md);
}

.modal-backdrop.show {
  opacity: 1;
  visibility: visible;
}

.modal {
  background: white;
  border-radius: var(--radius-xl);
  max-width: 600px;
  width: 100%;
  max-height: 90vh;
  overflow-y: auto;
  box-shadow: var(--shadow-2xl);
  transform: scale(0.9) translateY(20px);
  transition: transform var(--transition-base);
}

.modal-backdrop.show .modal {
  transform: scale(1) translateY(0);
}

.modal-header {
  padding: var(--spacing-xl);
  border-bottom: 1px solid rgba(0, 0, 0, 0.1);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.modal-title {
  font-size: var(--font-size-2xl);
  font-weight: 700;
  color: var(--color-text-primary);
}

.modal-close {
  width: 32px;
  height: 32px;
  border: none;
  background: transparent;
  border-radius: var(--radius-md);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background var(--transition-fast);
  font-size: 24px;
  color: var(--color-text-tertiary);
}

.modal-close:hover {
  background: rgba(0, 0, 0, 0.05);
}

.modal-body {
  padding: var(--spacing-xl);
}

.modal-footer {
  padding: var(--spacing-xl);
  border-top: 1px solid rgba(0, 0, 0, 0.1);
  display: flex;
  gap: var(--spacing-md);
  justify-content: flex-end;
}

/* ============================================
   TOAST NOTIFICATIONS
   ============================================ */
#toast-container {
  position: fixed;
  top: var(--spacing-xl);
  right: var(--spacing-xl);
  z-index: var(--z-toast);
  display: flex;
  flex-direction: column;
  gap: var(--spacing-md);
  pointer-events: none;
}

.toast {
  background: white;
  padding: var(--spacing-md) var(--spacing-lg);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-xl);
  min-width: 300px;
  max-width: 400px;
  opacity: 0;
  transform: translateX(100%);
  transition: all var(--transition-base);
  pointer-events: all;
  border-left: 4px solid var(--color-info);
}

.toast.show {
  opacity: 1;
  transform: translateX(0);
}

.toast-success {
  border-left-color: var(--color-success);
}

.toast-warning {
  border-left-color: var(--color-warning);
}

.toast-error {
  border-left-color: var(--color-error);
}

/* ============================================
   LOADING SPINNER
   ============================================ */
#global-loading {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: var(--z-modal);
  opacity: 0;
  visibility: hidden;
  transition: all var(--transition-base);
}

#global-loading.show {
  opacity: 1;
  visibility: visible;
}

.spinner {
  width: 48px;
  height: 48px;
  border: 4px solid rgba(255, 197, 7, 0.2);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* ============================================
   SERVICE TYPE CARD
   ============================================ */
.service-type-card {
  background: white;
  border-radius: var(--radius-xl);
  padding: var(--spacing-xl);
  text-align: center;
  cursor: pointer;
  transition: all var(--transition-base);
  border: 3px solid transparent;
  box-shadow: var(--shadow-md);
  position: relative;
  overflow: hidden;
}

.service-type-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4px;
  background: var(--gradient-primary);
  opacity: 0;
  transition: opacity var(--transition-base);
}

.service-type-card:hover {
  transform: translateY(-6px);
  box-shadow: var(--shadow-xl);
}

.service-type-card:hover::before {
  opacity: 1;
}

.service-type-card.selected {
  border-color: var(--color-primary);
  transform: translateY(-6px);
  box-shadow: var(--shadow-xl);
}

.service-type-card.selected::before {
  opacity: 1;
}

.service-type-icon {
  font-size: 3rem;
  margin-bottom: var(--spacing-md);
  display: block;
}

.service-type-name {
  font-size: var(--font-size-lg);
  font-weight: 700;
  color: var(--color-text-primary);
}

/* ============================================
   RESPONSIVE
   ============================================ */
@media (max-width: 767px) {
  #toast-container {
    top: var(--spacing-md);
    right: var(--spacing-md);
    left: var(--spacing-md);
  }

  .toast {
    min-width: auto;
    max-width: none;
  }

  .modal {
    max-width: 100%;
    border-radius: var(--radius-lg);
  }

  .service-card-image {
    height: 160px;
  }
}

/* ============================================
   MODERN SERVICE CARD (Mobil'den)
   ============================================ */
.modern-service-card {
  background: var(--color-bg-white);
  border-radius: var(--radius-xl);
  overflow: hidden;
  box-shadow: var(--shadow-card);
  transition: all var(--transition-base);
  position: relative;
}

.modern-service-card:hover {
  transform: translateY(-8px);
  box-shadow: var(--shadow-xl);
}

.modern-service-card-image {
  width: 100%;
  height: 180px;
  object-fit: cover;
}

.modern-service-card-content {
  padding: var(--spacing-lg);
}

.modern-service-card-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: var(--spacing-sm);
}

.modern-service-card-title {
  font-size: var(--font-size-lg);
  font-weight: 700;
  color: var(--color-text-primary);
  margin: 0;
}

.modern-service-card-rating {
  display: flex;
  align-items: center;
  gap: 4px;
  background: var(--color-primary-soft);
  padding: 4px 10px;
  border-radius: var(--radius-full);
  font-size: var(--font-size-sm);
  font-weight: 600;
}

.modern-service-card-meta {
  display: flex;
  align-items: center;
  gap: var(--spacing-md);
  color: var(--color-text-tertiary);
  font-size: var(--font-size-sm);
  margin-bottom: var(--spacing-md);
}

.modern-service-card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacing-xs);
}

/* ============================================
   CATEGORY CARD (Mobil'den)
   ============================================ */
.category-card {
  background: var(--color-bg-white);
  border-radius: var(--radius-xl);
  padding: var(--spacing-lg);
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  cursor: pointer;
  transition: all var(--transition-base);
  box-shadow: var(--shadow-card);
}

.category-card:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-lg);
}

.category-card-icon {
  width: 64px;
  height: 64px;
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 2rem;
  margin-bottom: var(--spacing-md);
  background: var(--gradient-primary);
}

.category-card-title {
  font-size: var(--font-size-sm);
  font-weight: 600;
  color: var(--color-text-primary);
  margin: 0;
}

.category-card-count {
  font-size: var(--font-size-xs);
  color: var(--color-text-muted);
  margin-top: 4px;
}

/* Category Color Variants */
.category-card[data-color="0"] .category-card-icon { background: linear-gradient(135deg, #FF6B35, #F7931E); }
.category-card[data-color="1"] .category-card-icon { background: linear-gradient(135deg, #4F46E5, #6366F1); }
.category-card[data-color="2"] .category-card-icon { background: linear-gradient(135deg, #10B981, #059669); }
.category-card[data-color="3"] .category-card-icon { background: linear-gradient(135deg, #F59E0B, #D97706); }
.category-card[data-color="4"] .category-card-icon { background: linear-gradient(135deg, #8B5CF6, #A78BFA); }
.category-card[data-color="5"] .category-card-icon { background: linear-gradient(135deg, #EF4444, #DC2626); }
.category-card[data-color="6"] .category-card-icon { background: linear-gradient(135deg, #06B6D4, #0891B2); }
.category-card[data-color="7"] .category-card-icon { background: linear-gradient(135deg, #84CC16, #65A30D); }

/* ============================================
   QUICK ACTION BUTTONS (Mobil'den)
   ============================================ */
.quick-actions {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--spacing-md);
  margin-bottom: var(--spacing-xl);
}

.quick-action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--spacing-xs);
  padding: var(--spacing-md);
  background: var(--color-bg-white);
  border-radius: var(--radius-lg);
  border: none;
  cursor: pointer;
  transition: all var(--transition-base);
  box-shadow: var(--shadow-sm);
}

.quick-action-btn:hover {
  transform: translateY(-2px);
  box-shadow: var(--shadow-md);
}

.quick-action-icon {
  width: 48px;
  height: 48px;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.5rem;
  background: var(--color-primary-soft);
}

.quick-action-label {
  font-size: var(--font-size-xs);
  font-weight: 600;
  color: var(--color-text-secondary);
  text-align: center;
}

/* Quick Action Color Variants */
.quick-action-btn[data-type="appointment"] .quick-action-icon {
  background: rgba(59, 130, 246, 0.1);
  color: #2563EB;
}

.quick-action-btn[data-type="roadside"] .quick-action-icon {
  background: rgba(239, 68, 68, 0.1);
  color: #DC2626;
}

.quick-action-btn[data-type="carwash"] .quick-action-icon {
  background: rgba(16, 185, 129, 0.1);
  color: #059669;
}

.quick-action-btn[data-type="search"] .quick-action-icon {
  background: var(--color-primary-soft);
  color: var(--color-primary-dark);
}

@media (max-width: 767px) {
  .quick-actions {
    grid-template-columns: repeat(2, 1fr);
  }
}

/* ============================================
   ROADSIDE ASSISTANCE CARD (Mobil'den)
   ============================================ */
.roadside-card {
  background: linear-gradient(135deg, #FEF2F2 0%, #FFFFFF 100%);
  border-radius: var(--radius-xl);
  padding: var(--spacing-lg);
  border: 2px solid rgba(239, 68, 68, 0.2);
  position: relative;
  overflow: hidden;
}

.roadside-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 4px;
  height: 100%;
  background: linear-gradient(180deg, #EF4444, #DC2626);
}

.roadside-card-header {
  display: flex;
  align-items: center;
  gap: var(--spacing-md);
  margin-bottom: var(--spacing-md);
}

.roadside-card-icon {
  width: 56px;
  height: 56px;
  border-radius: var(--radius-lg);
  background: rgba(239, 68, 68, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.75rem;
}

.roadside-card-title {
  font-size: var(--font-size-lg);
  font-weight: 700;
  color: var(--color-text-primary);
  margin: 0;
}

.roadside-card-subtitle {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
  margin: 0;
}

.roadside-card-features {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacing-sm);
  margin-bottom: var(--spacing-lg);
}

.roadside-card-feature {
  display: flex;
  align-items: center;
  gap: 4px;
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

/* ============================================
   CAR WASH CARD (Mobil'den)
   ============================================ */
.carwash-card {
  background: linear-gradient(135deg, #ECFDF5 0%, #FFFFFF 100%);
  border-radius: var(--radius-xl);
  padding: var(--spacing-lg);
  border: 2px solid rgba(16, 185, 129, 0.2);
  position: relative;
  overflow: hidden;
}

.carwash-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 4px;
  height: 100%;
  background: linear-gradient(180deg, #10B981, #059669);
}

.carwash-card-header {
  display: flex;
  align-items: center;
  gap: var(--spacing-md);
  margin-bottom: var(--spacing-md);
}

.carwash-card-icon {
  width: 56px;
  height: 56px;
  border-radius: var(--radius-lg);
  background: rgba(16, 185, 129, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.75rem;
}

/* ============================================
   EV CHARGING CARD (Mobil'den)
   ============================================ */
.ev-charging-card {
  background: linear-gradient(135deg, #EFF6FF 0%, #FFFFFF 100%);
  border-radius: var(--radius-xl);
  padding: var(--spacing-lg);
  border: 2px solid rgba(59, 130, 246, 0.2);
  position: relative;
  overflow: hidden;
}

.ev-charging-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 4px;
  height: 100%;
  background: linear-gradient(180deg, #3B82F6, #2563EB);
}

/* ============================================
   CAMPAIGN CARD (Mobil'den)
   ============================================ */
.campaign-card {
  background: var(--color-bg-white);
  border-radius: var(--radius-xl);
  overflow: hidden;
  box-shadow: var(--shadow-card);
  transition: all var(--transition-base);
}

.campaign-card:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-lg);
}

.campaign-card-image {
  width: 100%;
  height: 200px;
  object-fit: cover;
}

.campaign-card-content {
  padding: var(--spacing-lg);
}

.campaign-card-badge {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 4px 12px;
  background: var(--gradient-primary);
  border-radius: var(--radius-full);
  font-size: var(--font-size-xs);
  font-weight: 700;
  margin-bottom: var(--spacing-sm);
}

.campaign-card-title {
  font-size: var(--font-size-lg);
  font-weight: 700;
  color: var(--color-text-primary);
  margin: 0 0 var(--spacing-sm) 0;
}

.campaign-card-description {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
  margin: 0;
  line-height: 1.5;
}

/* ============================================
   APPOINTMENT UPCOMING CARD (Mobil'den)
   ============================================ */
.appointment-upcoming-card {
  background: linear-gradient(135deg, #EFF6FF 0%, #FFFFFF 100%);
  border-radius: var(--radius-xl);
  padding: var(--spacing-lg);
  border: 2px solid rgba(59, 130, 246, 0.2);
  display: flex;
  gap: var(--spacing-lg);
  align-items: center;
}

.appointment-date-box {
  min-width: 70px;
  text-align: center;
  padding: var(--spacing-md);
  background: white;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
}

.appointment-date-day {
  font-size: var(--font-size-3xl);
  font-weight: 700;
  color: var(--color-primary-dark);
  line-height: 1;
}

.appointment-date-month {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
  text-transform: uppercase;
  font-weight: 600;
}

.appointment-info {
  flex: 1;
}

.appointment-info-title {
  font-size: var(--font-size-lg);
  font-weight: 700;
  color: var(--color-text-primary);
  margin: 0 0 4px 0;
}

.appointment-info-subtitle {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
  margin: 0;
}

/* ============================================
   SEARCH BOX MODERN (Mobil'den)
   ============================================ */
.search-box-modern {
  background: var(--color-bg-white);
  border-radius: var(--radius-xl);
  padding: var(--spacing-md);
  box-shadow: var(--shadow-card);
  display: flex;
  align-items: center;
  gap: var(--spacing-md);
}

.search-box-modern-icon {
  width: 48px;
  height: 48px;
  border-radius: var(--radius-lg);
  background: var(--gradient-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.25rem;
}

.search-box-modern-input {
  flex: 1;
  border: none;
  outline: none;
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
  background: transparent;
}

.search-box-modern-input::placeholder {
  color: var(--color-text-muted);
}

/* ============================================
   SECTION CARD (Generic)
   ============================================ */
.section-card {
  background: var(--color-bg-white);
  border-radius: var(--radius-xl);
  padding: var(--spacing-xl);
  margin-bottom: var(--spacing-xl);
  box-shadow: var(--shadow-card);
}

.section-card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--spacing-lg);
}

.section-card-title {
  font-size: var(--font-size-xl);
  font-weight: 700;
  color: var(--color-text-primary);
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
}

.section-card-title-icon {
  font-size: 1.25rem;
}

.section-card-link {
  font-size: var(--font-size-sm);
  font-weight: 600;
  color: var(--color-primary-dark);
  display: flex;
  align-items: center;
  gap: 4px;
  cursor: pointer;
}

.section-card-link:hover {
  color: var(--color-text-primary);
}

/* ============================================
   HORIZONTAL SCROLL CONTAINER (Mobil'den)
   ============================================ */
.horizontal-scroll {
  display: flex;
  gap: var(--spacing-md);
  overflow-x: auto;
  padding-bottom: var(--spacing-sm);
  scroll-snap-type: x mandatory;
  -webkit-overflow-scrolling: touch;
}

.horizontal-scroll::-webkit-scrollbar {
  display: none;
}

.horizontal-scroll > * {
  flex-shrink: 0;
  scroll-snap-align: start;
}

/* ============================================
   LOADING SKELETON CARDS
   ============================================ */
.skeleton-service-card {
  background: var(--color-bg-white);
  border-radius: var(--radius-xl);
  overflow: hidden;
}

.skeleton-service-card-image {
  height: 180px;
  background: var(--skeleton-gradient, linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%));
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
}

.skeleton-service-card-content {
  padding: var(--spacing-lg);
}

.skeleton-service-card-title {
  height: 20px;
  width: 70%;
  margin-bottom: var(--spacing-sm);
  background: var(--skeleton-gradient, linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%));
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: var(--radius-sm);
}

.skeleton-service-card-text {
  height: 14px;
  width: 90%;
  margin-bottom: 8px;
  background: var(--skeleton-gradient, linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%));
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: var(--radius-sm);
}
